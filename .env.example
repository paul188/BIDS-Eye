# Copy this to .env and fill in your values.

# ── Gemini API ─────────────────────────────────────────────────────────────────
# Required for text-to-SQL (preprocessing + SQL generation + error correction)
GEMINI_API_KEY=your_gemini_api_key_here

# ── Anthropic API (optional) ────────────────────────────────────────────────────
# Cross-provider fallback tier: used only when all Gemini models fail (e.g. 503).
# If unset, the cascade is Gemini-only. Default fallback model: claude-sonnet-4-6.
ANTHROPIC_API_KEY=
# ANTHROPIC_FALLBACK_MODEL=claude-sonnet-4-6
# GEMINI_MODEL_CASCADE=gemini-2.5-flash,gemini-2.5-pro,gemini-2.5-flash-lite,gemini-2.0-flash

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
METADATA_DB_NAME=bids_sql
METADATA_DB_USER=user
METADATA_DB_PASSWORD=password
METADATA_DB_HOST=db        # use 'localhost' when running outside Docker
METADATA_DB_PORT=5432

# ── Authentication ─────────────────────────────────────────────────────────────
# GitHub OAuth App credentials (create one at https://github.com/settings/developers)
# Callback URL to register in the GitHub OAuth App: https://<your-domain>/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Optional: restrict access to members of a specific GitHub org (leave blank to allow any GitHub user)
GITHUB_ORG=
# Override the OAuth callback URL — needed when behind a reverse proxy that rewrites the host.
# Defaults to the inferred request URL if unset (usually fine for local dev).
GITHUB_REDIRECT_URI=
# Secrets used to sign JWTs and OAuth state cookies
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-before-deploying
SECRET_KEY=change-me-before-deploying
# Your public frontend URL — used to restrict CORS and to redirect the browser after login
# (e.g. https://bids-eye.yourdomain.com)
FRONTEND_URL=*

# ── App behaviour ──────────────────────────────────────────────────────────────
IN_PRODUCTION=false        # set to 'true' in production
# Free messages per user per day (resets at UTC midnight)
DAILY_MESSAGE_LIMIT=20

# ── OpenNeuro crawler ──────────────────────────────────────────────────────────
# Comma-separated accession IDs to crawl (overrides accessions.yaml)
OPENNEURO_ACCESSIONS=ds000001,ds000002

# How often to re-run the full crawl cycle (hours)
CRAWL_INTERVAL_HOURS=1

# Sleep between consecutive datasets (seconds) — keep this ≥ 10 to be polite
CRAWL_DELAY_SECONDS=30
