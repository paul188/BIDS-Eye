# Copy this to .env and fill in your values.

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
METADATA_DB_NAME=bids_eye
METADATA_DB_USER=bids
METADATA_DB_PASSWORD=changeme
METADATA_DB_HOST=localhost
METADATA_DB_PORT=5432

# ── OpenNeuro crawler ──────────────────────────────────────────────────────────
# Comma-separated accession IDs to crawl (overrides accessions.yaml)
OPENNEURO_ACCESSIONS=ds000001,ds000002

# How often to re-run the full crawl cycle (hours)
CRAWL_INTERVAL_HOURS=1

# Sleep between consecutive datasets (seconds) — keep this ≥ 10 to be polite
CRAWL_DELAY_SECONDS=30
