# Copy this to .env and fill in your values.

# ── Gemini API ─────────────────────────────────────────────────────────────────
# Required for text-to-SQL (preprocessing + SQL generation + error correction)
GEMINI_API_KEY=your_gemini_api_key_here

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
METADATA_DB_NAME=bids_sql
METADATA_DB_USER=user
METADATA_DB_PASSWORD=password
METADATA_DB_HOST=db        # use 'localhost' when running outside Docker
METADATA_DB_PORT=5432

# ── App behaviour ──────────────────────────────────────────────────────────────
IN_PRODUCTION=false        # set to 'true' in production

# ── Modal serverless inference (only needed for GPU/SQLCoder deployment) ───────
# Get these from https://modal.com/settings/tokens
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# Modal deploy-time tuning (read by modal_app/app.py at deploy time, not at runtime)
# MODAL_MIN_CONTAINERS=1  → always keep one container warm → no cold starts (~$1/hr for A10G)
# MODAL_MIN_CONTAINERS=0  → scale to zero when idle → free, but 2-4 min cold start
MODAL_MIN_CONTAINERS=0
# Token budget for SQLCoder. 300 is fast and sufficient; 512 is the safe maximum.
MODAL_MAX_NEW_TOKENS=512
# How long (seconds) to keep a container alive after the last request.
MODAL_SCALEDOWN_SECS=300

# ── OpenNeuro crawler ──────────────────────────────────────────────────────────
# Comma-separated accession IDs to crawl (overrides accessions.yaml)
OPENNEURO_ACCESSIONS=ds000001,ds000002

# How often to re-run the full crawl cycle (hours)
CRAWL_INTERVAL_HOURS=1

# Sleep between consecutive datasets (seconds) — keep this ≥ 10 to be polite
CRAWL_DELAY_SECONDS=30
