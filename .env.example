# Copy this to .env and fill in your values.

# ── Gemini API ─────────────────────────────────────────────────────────────────
# Required for text-to-SQL (preprocessing + SQL generation + error correction)
GEMINI_API_KEY=your_gemini_api_key_here

# ── Anthropic API (optional) ────────────────────────────────────────────────────
# Cross-provider fallback tier: used only when all Gemini models fail (e.g. 503).
# If unset, the cascade is Gemini-only. Default fallback model: claude-sonnet-4-6.
ANTHROPIC_API_KEY=
# ANTHROPIC_FALLBACK_MODEL=claude-sonnet-4-6
# GEMINI_MODEL_CASCADE=gemini-2.5-flash,gemini-2.5-pro,gemini-2.5-flash-lite,gemini-2.0-flash

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
METADATA_DB_NAME=bids_sql
METADATA_DB_USER=user
METADATA_DB_PASSWORD=password
METADATA_DB_HOST=db        # use 'localhost' when running outside Docker
METADATA_DB_PORT=5432

# ── Authentication ─────────────────────────────────────────────────────────────
# Password users must enter to access the app
AUTH_PASSWORD=change-me-before-deploying
# Secret used to sign JWTs — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-before-deploying
# Your public frontend URL — used to restrict CORS (e.g. https://bids-eye.yourdomain.com)
FRONTEND_URL=*

# ── App behaviour ──────────────────────────────────────────────────────────────
IN_PRODUCTION=false        # set to 'true' in production

# ── OpenNeuro crawler ──────────────────────────────────────────────────────────
# Comma-separated accession IDs to crawl (overrides accessions.yaml)
OPENNEURO_ACCESSIONS=ds000001,ds000002

# How often to re-run the full crawl cycle (hours)
CRAWL_INTERVAL_HOURS=1

# Sleep between consecutive datasets (seconds) — keep this ≥ 10 to be polite
CRAWL_DELAY_SECONDS=30
